model Participant {
    id String @id @default(uuid())

    name        String?
    email       String
    isConfirmed Boolean @default(false) @map("is_confirmed")
    isOwner     Boolean @default(false) @map("is_owner")

    tripId String @map("trip_id")

    trip Trip @relation(fields: [tripId], references: [id])

    @@map("participants")
}
